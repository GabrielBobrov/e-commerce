# .env
# Este arquivo centraliza a configuração do ambiente local para o Docker Compose.

# --- AWS / Terraform ---
# Execute 'terraform apply' e copie o valor de 'order_events_topic_arn' para cá.
ORDER_EVENTS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:order-events-topic

# --- PostgreSQL ---
DB_HOST=db
DB_PORT=5432
DB_NAME=order_db
DB_USER=paymentuser
DB_PASSWORD=paymentpass

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- LocalStack ---
LOCALSTACK_HOST=localstack
LOCALSTACK_PORT=4566